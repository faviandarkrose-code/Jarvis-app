[app]
title = Jarvis
package.name = jarvis
package.domain = com.jarvis.app
source.dir = .
source.include_exts = py,png,jpg,kv,atlas
version = 1.0
requirements = python3,kivy,requests
orientation = portrait
fullscreen = 0
android.permissions = INTERNET
android.api = 33
android.minapi = 21
log_level = 2
warn_on_root = 0

[buildozer]
log_level = 2
warn_on_root = 0
